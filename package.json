{
  "name": "atom-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "tsx watch src/server/main.ts",
    "dev:client": "vite",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build",
    "build:server": "esbuild src/server/main.ts --bundle --platform=node --format=esm --outfile=dist/server/main.js --packages=external --sourcemap --target=node20 --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "start": "node dist/server/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.tools.json",
    "lint": "oxlint -c .oxlintrc.jsonc --quiet",
    "lint:fix": "oxlint -c .oxlintrc.jsonc --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "vapid": "tsx scripts/gen-vapid.ts"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.1.0",
    "@fontsource/geist-mono": "^5.1.0",
    "@fontsource/inter": "^5.1.0",
    "@hono/node-server": "^1.13.7",
    "@hono/trpc-server": "^0.3.4",
    "@milkdown/crepe": "^7.5.0",
    "@milkdown/kit": "^7.5.0",
    "@milkdown/react": "^7.5.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "7.7.0",
    "@tanstack/react-query": "^5.62.0",
    "@trpc/client": "^11.0.0-rc.648",
    "@trpc/react-query": "^11.0.0-rc.648",
    "@trpc/server": "^11.0.0-rc.648",
    "better-sqlite3": "^11.7.0",
    "cookie": "^1.0.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "node-cron": "^3.0.3",
    "prisma": "7.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "superjson": "^2.2.2",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0-beta.8",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cookie": "^0.6.0",
    "@types/node": "^22.10.1",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "concurrently": "^9.1.0",
    "esbuild": "^0.28.0",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "tailwindcss": "^4.0.0-beta.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^0.21.1",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "workbox-window": "^7.3.0"
  },
  "packageManager": "pnpm@10.29.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "better-sqlite3",
      "esbuild",
      "prisma"
    ]
  }
}
