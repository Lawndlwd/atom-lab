NODE_ENV=development
PORT=5174
DATABASE_URL=file:./data/identity.db

# Auth
SESSION_COOKIE_NAME=sid
SESSION_COOKIE_SECURE=false
SESSION_TTL_DAYS=30

# Signup gate
ALLOWED_EMAILS=
OPEN_SIGNUP=true

# Web-push (run: pnpm vapid to generate)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Client-visible VAPID public key (Vite exposes VITE_* vars to browser)
VITE_VAPID_PUBLIC_KEY=
